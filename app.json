{
  "expo": {
    "name": "GMAConnect",
    "slug": "gma-mobile",
    "owner": "gma-app",
    "version": "1.0.1",
    "scheme": "gmamobile",
    "splash": {
      "image": "./assets/images/gma-flash-logo.png",
      "resizeMode": "cover",
      "backgroundColor": "#FBF0E4"
    },
    "android": {
      "package": "com.gma.connect",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/gma-app-logo.png",
        "backgroundColor": "#FBF0E4"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "kit300-p4-gma.firebaseapp.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "kit300-p4-gma.web.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/auth",
      "expo-splash-screen",
      "@react-native-google-signin/google-signin",
      "react-native-fbsdk-next"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "com.gma.connect",
      "associatedDomains": [
        "applinks:kit300-p4-gma.firebaseapp.com",
        "applinks:kit300-p4-gma.web.app"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "c2d2ee93-087d-4c06-8b37-d4e70f5f5153"
      },
      "googleWebClientId": "1056021584152-0ks0i3jlit8dl8b85di729bbkqirilsr.apps.googleusercontent.com"
    }
  }
}