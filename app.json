{
  "expo": {
    "name": "gma-mobile",
    "slug": "gma-mobile",
    "version": "1.0.1",
    "scheme": "gmamobile",
   
    "android": {
      "package": "com.gma.connect",
      "googleServicesFile": "google-services.json"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app" 
        }
      ],
      
      "@react-native-firebase/auth",
      "expo-splash-screen"
      // ... keep your other plugins here
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}