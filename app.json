{
  "expo": {
    "name": "gma-mobile",
    "slug": "gma-mobile",
    "version": "1.0.1",
    "scheme": "gmamobile",
   
    "android": {
      "package": "com.gma.connect",
      "googleServicesFile": "google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "kit300-p4-gma.firebaseapp.com",
              "pathPrefix": "/__/auth/action"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app" 
        }
      ],
      "@react-native-firebase/auth",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}