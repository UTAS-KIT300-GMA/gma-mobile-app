/*
Default `tsconfig.json` provided by Expo, with some customizations:

- Added `strict` mode for better type safety.
- Configured `jsx` to use the new React JSX transform.
- Set `module` to `ESNext` for better tree-shaking and modern module support.
- Added path alias `@/*` to simplify imports from the `src` directory.
*/

{
  // TypeScript config file.
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    // "lib": ["ESNext"],
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    // Shortcuts to other folders in src.
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  // The only files TypeScript will check for errors.
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "**/*.d.ts"
  ]
}
